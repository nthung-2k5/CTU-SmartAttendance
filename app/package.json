{
  "name": "server",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run dev:server && bun run dev:web",
    "dev:server": "bun run --watch server/index.ts",
    "server:inspect": "bun --inspect server/index.ts",
    "dev:web": "cd dashboard && bun run dev",
    "gen:proto": "bunx --bun buf generate",
    "build": "bun build --compile --target bun --outfile server server/src/index.ts",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:push": "bun --bun drizzle-kit push",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:studio": "bun --bun drizzle-kit studio"
